# Railway api service example

NODE_ENV=production
LOG_LEVEL=info
PORT=4000

DATABASE_URL=postgresql://...
DIRECT_DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# Private api -> worker traffic over Railway networking.
WORKER_RENDER_URL=http://worker.railway.internal:4100
WORKER_INTERNAL_TOKEN=

# Public browser origin for cookies and CORS.
ALLOWED_BROWSER_ORIGINS=https://app.example.com
AUTH_COOKIE_SECURE=true

API_REQUEST_TIMEOUT_MS=15000
API_BODY_LIMIT_BYTES=16384
API_STARTUP_CHECK_TIMEOUT_MS=5000
API_STARTUP_MAX_ATTEMPTS=12
API_STARTUP_RETRY_DELAY_MS=2000
