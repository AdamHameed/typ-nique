{
  "name": "@typ-nique/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev --name init",
    "deploy": "prisma migrate deploy",
    "seed:content": "pnpm run build && tsx prisma/seed-content.ts",
    "seed": "pnpm run build && tsx prisma/seed.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@typ-nique/typst-utils": "workspace:*",
    "@typ-nique/validation": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2"
  },
  "prisma": {
    "seed": "pnpm run build && tsx prisma/seed.ts"
  }
}
