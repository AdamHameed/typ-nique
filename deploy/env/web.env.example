# Railway web service example

NODE_ENV=production
PORT=3000

# Server-side web -> api traffic over Railway private networking.
API_INTERNAL_URL=http://api.railway.internal:4000

# Optional. Leave empty when browser REST should stay same-origin through the web proxy.
NEXT_PUBLIC_API_URL=

# Public browser WebSocket origin for multiplayer.
NEXT_PUBLIC_MULTIPLAYER_GATEWAY_URL=https://api.example.com

NEXT_PUBLIC_ENABLE_MULTIPLAYER_DIAGNOSTICS=false
