COMPOSE_PROJECT_NAME=typnique-prod

# Immutable or otherwise explicit runtime image refs.
TYPNIQUE_WEB_IMAGE=ghcr.io/<owner>/typ-nique-web:sha-<shortsha>
TYPNIQUE_API_IMAGE=ghcr.io/<owner>/typ-nique-api:sha-<shortsha>
TYPNIQUE_WORKER_IMAGE=ghcr.io/<owner>/typ-nique-worker:sha-<shortsha>

# Local ports exposed by the production-like stack.
WEB_PORT=3000
API_PORT=4000
WORKER_PORT=4100
POSTGRES_PORT=5432
REDIS_PORT=6379

# Local backing service credentials.
POSTGRES_DB=typ_nique
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Shared app secrets and externally visible browser settings.
WORKER_INTERNAL_TOKEN=replace-me-with-a-long-random-string
ALLOWED_BROWSER_ORIGINS=http://localhost:3000
AUTH_COOKIE_SECURE=false
NEXT_PUBLIC_MULTIPLAYER_GATEWAY_URL=ws://localhost:4000

# Optional production-like tuning knobs.
API_LOG_LEVEL=info
WORKER_LOG_LEVEL=info
ENABLE_RENDER_ADMIN=false
TYPST_TIMEOUT_MS=4000
TYPST_MAX_MEMORY_KB=524288
TYPST_MAX_CONCURRENT_RENDERS=2
