{
  "name": "typ-nique",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "bash ./scripts/dev-stack.sh",
    "dev:no-seed": "bash ./scripts/dev-stack.sh --no-seed",
    "dev:reset": "bash ./scripts/dev-stack.sh --reset",
    "dev:workspace": "turbo dev",
    "stop": "bash ./scripts/reset-stack.sh",
    "stop:reset": "bash ./scripts/reset-stack.sh --volumes",
    "infra:up": "docker compose -f infra/compose/docker-compose.yml up -d postgres redis",
    "infra:down": "docker compose -f infra/compose/docker-compose.yml down",
    "infra:reset": "docker compose -f infra/compose/docker-compose.yml down -v",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @typ-nique/db generate",
    "db:migrate": "pnpm --filter @typ-nique/db migrate",
    "db:deploy": "pnpm --filter @typ-nique/db deploy",
    "db:seed": "pnpm --filter @typ-nique/db seed",
    "content:validate": "tsx scripts/challenges/validate.ts",
    "content:render": "tsx scripts/challenges/render.ts",
    "content:hash": "tsx scripts/challenges/hash.ts",
    "content:seed": "tsx scripts/challenges/seed.ts",
    "test": "vitest run",
    "test:checker": "pnpm --dir packages/checker exec vitest run --config vitest.config.ts",
    "test:api:unit": "pnpm --dir apps/api exec vitest run --config vitest.unit.config.ts",
    "test:api:integration": "pnpm --dir apps/api exec vitest run --config vitest.integration.config.ts",
    "test:web": "pnpm --dir apps/web exec vitest run --config vitest.config.ts",
    "test:unit": "vitest run --project checker --project api --project web",
    "test:integration": "pnpm test:api:integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:ci": "pnpm test:coverage && pnpm test:e2e",
    "test:e2e:install": "playwright install --with-deps chromium",
    "build:verify": "pnpm build",
    "docker:build:api": "docker build -f infra/docker/api.Dockerfile -t typ-nique-api:ci .",
    "docker:build:web": "docker build -f infra/docker/web.Dockerfile -t typ-nique-web:ci .",
    "docker:build:worker": "docker build -f infra/docker/worker.Dockerfile -t typ-nique-worker:ci .",
    "docker:build": "pnpm docker:build:api && pnpm docker:build:web && pnpm docker:build:worker",
    "ci:lint": "pnpm lint",
    "ci:typecheck": "pnpm typecheck",
    "ci:test:unit": "pnpm test:checker && pnpm test:api:unit && pnpm test:web",
    "ci:test:integration": "pnpm test:integration",
    "ci:build": "pnpm build:verify",
    "ci:docker": "pnpm docker:build",
    "ci:verify": "pnpm ci:lint && pnpm ci:typecheck && pnpm ci:test:unit && pnpm ci:test:integration && pnpm ci:build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "dotenv-cli": "^7.4.2",
    "jsdom": "^24.1.3",
    "playwright": "^1.59.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.8"
  }
}
