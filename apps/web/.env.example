# Web service example for production documentation.
# Only NEXT_PUBLIC_* values are exposed to the browser bundle.

NODE_ENV=production
PORT=3000
API_INTERNAL_URL=http://api:4000
NEXT_PUBLIC_API_URL=https://app.example.com
NEXT_PUBLIC_MULTIPLAYER_GATEWAY_URL=https://api.example.com
NEXT_PUBLIC_ENABLE_MULTIPLAYER_DIAGNOSTICS=false
