# Local full-stack development example only.
# Production services should set environment variables directly in the platform
# and should not rely on loading this file at runtime.

NODE_ENV=development
LOG_LEVEL=debug
PORT=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/typ_nique
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/typ_nique
REDIS_URL=redis://localhost:6379
API_INTERNAL_URL=http://127.0.0.1:4000
WORKER_RENDER_URL=http://127.0.0.1:4100
WORKER_INTERNAL_TOKEN=
RENDER_ADMIN_TOKEN=
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MULTIPLAYER_GATEWAY_URL=
ALLOWED_BROWSER_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PORT=4000
API_REQUEST_TIMEOUT_MS=15000
API_BODY_LIMIT_BYTES=16384
API_STARTUP_CHECK_TIMEOUT_MS=5000
API_STARTUP_MAX_ATTEMPTS=12
API_STARTUP_RETRY_DELAY_MS=2000
WEB_PORT=3000
WORKER_PORT=4100
WORKER_REQUEST_TIMEOUT_MS=15000
WORKER_BODY_LIMIT_BYTES=16384
WORKER_STARTUP_CHECK_TIMEOUT_MS=5000
WORKER_STARTUP_MAX_ATTEMPTS=12
WORKER_STARTUP_RETRY_DELAY_MS=2000
WORKER_SHUTDOWN_TIMEOUT_MS=10000
QUEUE_NAME=render-jobs
AUTH_COOKIE_NAME=typ_nique_auth
GUEST_COOKIE_NAME=typ_nique_guest
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
ENABLE_MULTIPLAYER_DIAGNOSTICS=
NEXT_PUBLIC_ENABLE_MULTIPLAYER_DIAGNOSTICS=
ENABLE_RENDER_ADMIN=
AUTH_SESSION_TTL_DAYS=30
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
LEADERBOARD_RATE_LIMIT_WINDOW_MS=60000
LEADERBOARD_RATE_LIMIT_MAX=120
MULTIPLAYER_RATE_LIMIT_WINDOW_MS=60000
MULTIPLAYER_RATE_LIMIT_MAX=90
MULTIPLAYER_WS_CONNECTION_RATE_LIMIT_WINDOW_MS=60000
MULTIPLAYER_WS_CONNECTION_RATE_LIMIT_MAX=24
MULTIPLAYER_WS_MESSAGE_RATE_LIMIT_WINDOW_MS=10000
MULTIPLAYER_WS_MESSAGE_RATE_LIMIT_MAX=60
WEBSOCKET_MAX_PAYLOAD_BYTES=4096
PREVIEW_RATE_LIMIT_WINDOW_MS=60000
PREVIEW_RATE_LIMIT_MAX=45
SUBMISSION_RATE_LIMIT_WINDOW_MS=60000
SUBMISSION_RATE_LIMIT_MAX=90
TYPST_BIN=typst
TYPST_TIMEOUT_MS=4000
TYPST_MAX_MEMORY_KB=524288
TYPST_MAX_CONCURRENT_RENDERS=2
TYPST_MAX_SOURCE_BYTES=12000
TYPST_MAX_OUTPUT_BYTES=262144
TYPST_MAX_LOG_BYTES=16384
TYPST_TEMP_ROOT_DIR=/tmp
TYPST_WORKSPACE_MAX_AGE_MS=900000
RENDER_CACHE_TTL_MS=300000
RENDER_FAILURE_CACHE_TTL_MS=30000
RENDER_CACHE_MAX_ENTRIES=500
ARTIFACTS_DIR=/app/storage
